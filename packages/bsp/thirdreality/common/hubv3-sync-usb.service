[Unit]
Description=Thirdreality USB auto sync Service
After=basic.target

[Service]
Type=simple
ExecStart=/bin/bash /usr/lib/thirdreality/hubv3-sync-usb.sh
Restart=on-failure
StandardOutput=journal
StandardError=journal
SyslogIdentifier=hubv3-sync-usb
User=root

[Install]
WantedBy=multi-user.target
