#!/bin/bash

LED_STATE="W"  # LED默认颜色
INTERVAL=1      # LED开关间隔（秒）
PID_FILE="/run/led_control.pid"
STATE_FILE="/run/led_state"

# GPIO配置
GPIO_RED=414
GPIO_GREEN=430
GPIO_BLUE=431

# 初始化 GPIO 引脚
init_gpio() {
    for gpio in $GPIO_RED $GPIO_GREEN $GPIO_BLUE; do
        if [ ! -d "/sys/class/gpio/gpio$gpio" ]; then
            echo "$gpio" > /sys/class/gpio/export
        fi
        echo "out" > "/sys/class/gpio/gpio$gpio/direction"
    done
}

# 清理 GPIO 引脚
cleanup_gpio() {
    for gpio in $GPIO_RED $GPIO_GREEN $GPIO_BLUE; do
        if [ -d "/sys/class/gpio/gpio$gpio" ]; then
            echo "0" > "/sys/class/gpio/gpio$gpio/value"
            echo "$gpio" > /sys/class/gpio/unexport
        fi
    done
}

# 启动 LED 定时开关
start() {
    if [ -f "$PID_FILE" ]; then
        echo "脚本已在运行中!"
        exit 1
    fi

    if [ ! -e "/etc/wpa_supplicant/wpa_supplicant-nl80211-wlan0.conf" ]; then
        INTERVAL=0.5
    fi

    echo $$ > "$PID_FILE"
    echo "$LED_STATE" > "$STATE_FILE"
    echo "LED控制启动, 当前颜色为 $LED_STATE, 间隔为 $INTERVAL 秒"

    trap "cleanup_gpio; rm -f $PID_FILE $STATE_FILE; exit 0" INT TERM

    while true; do
        # 动态读取 LED 状态
        LED_STATE=$(cat "$STATE_FILE")

        if [ "$LED_STATE" = "B-" ]; then
            echo 1 > "/sys/class/gpio/gpio$GPIO_BLUE/value"
            sleep 1
            continue  # 继续下一次循环，不执行熄灭逻辑
        fi

        case "$LED_STATE" in
            R)
                echo 1 > "/sys/class/gpio/gpio$GPIO_RED/value"
                echo 0 > "/sys/class/gpio/gpio$GPIO_GREEN/value"
                echo 0 > "/sys/class/gpio/gpio$GPIO_BLUE/value"
                ;;
            G)
                echo 0 > "/sys/class/gpio/gpio$GPIO_RED/value"
                echo 1 > "/sys/class/gpio/gpio$GPIO_GREEN/value"
                echo 0 > "/sys/class/gpio/gpio$GPIO_BLUE/value"
                ;;
            B)
                echo 0 > "/sys/class/gpio/gpio$GPIO_RED/value"
                echo 0 > "/sys/class/gpio/gpio$GPIO_GREEN/value"
                echo 1 > "/sys/class/gpio/gpio$GPIO_BLUE/value"
                ;;
            Y)
                echo 1 > "/sys/class/gpio/gpio$GPIO_RED/value"
                echo 1 > "/sys/class/gpio/gpio$GPIO_GREEN/value"
                echo 0 > "/sys/class/gpio/gpio$GPIO_BLUE/value"
                ;;
            W)
                echo 1 > "/sys/class/gpio/gpio$GPIO_RED/value"
                echo 1 > "/sys/class/gpio/gpio$GPIO_GREEN/value"
                echo 1 > "/sys/class/gpio/gpio$GPIO_BLUE/value"
                ;;
        esac

        sleep "$INTERVAL"

        # 关闭所有引脚
        echo 0 > "/sys/class/gpio/gpio$GPIO_RED/value"
        echo 0 > "/sys/class/gpio/gpio$GPIO_GREEN/value"
        echo 0 > "/sys/class/gpio/gpio$GPIO_BLUE/value"

        sleep "$INTERVAL"
    done
}

# 停止 LED 控制
stop() {
    if [ ! -f "$PID_FILE" ]; then
        echo "脚本未运行"
        exit 1
    fi

    PID=$(cat "$PID_FILE")
    kill "$PID" 2>/dev/null
    rm -f "$PID_FILE" "$STATE_FILE"
    echo "LED控制已停止"
    cleanup_gpio
    exit 0
}

# 修改 LED 状态
setstate() {
    case $1 in
        R|G|B|W|Y|B-)
            echo "$1" > "$STATE_FILE"
            echo "LED颜色已设置为 $1"
            ;;
        *)
            echo "无效的颜色设置。请使用 'R', 'G', 'B', 'Y', 'W' 或 'B-'."
            ;;
    esac
}

# 主入口
case $1 in
    start)
        init_gpio
        start
        ;;
    stop)
        stop
        ;;
    setstate)
        setstate "$2"
        ;;
    *)
        echo "用法: $0 {start|stop|setstate [R|G|B|Y|W|B-]}"
        exit 1
        ;;
esac

