[Unit]
Description=HubV3 LED Control Service
Before=basic.target
DefaultDependencies=no

[Service]
Type=simple
ExecStart=/usr/lib/armbian/hubv3-led-ctrl start
ExecStop=/usr/lib/armbian/hubv3-led-ctrl stop
Restart=always
PIDFile=/run/led_control.pid
TimeoutStartSec=10

[Install]
WantedBy=basic.target
