+	unsigned char cmd = 0;
+
+	if (!buf || 0 != kstrtou8(buf, 0, &cmd))
+		return ret;
+
+	WIFI_INFO("wifi power ctrl: cmd = %d\n", (int)cmd);
+	switch (cmd) {
+	case 1:
