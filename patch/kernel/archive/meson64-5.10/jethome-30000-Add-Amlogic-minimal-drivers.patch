+			goto err_mem_alloc;
+		size += DHD_PREALLOC_DHD_LOG_DUMP_BUF_EX_SIZE;
+		DHD_STATIC_TRACE("sectoin %d, size=%d\n",
+			DHD_PREALLOC_DHD_LOG_DUMP_BUF_EX,
