From 7adbbe97385549222a6f4ab922e0d3d3836f6720 Mon Sep 17 00:00:00 2001
From: "guoping.liu" <guoping.liu@3reality.com>
Date: Tue, 11 Mar 2025 23:37:44 -0400
Subject: [PATCH] change zigbee uart pins

---
 .../amlogic/meson-axg-jethome-jethub-j1xx.dtsi | 18 +++++++++---------
 1 file changed, 9 insertions(+), 9 deletions(-)

diff --git a/arch/arm64/boot/dts/amlogic/meson-axg-jethome-jethub-j1xx.dtsi b/arch/arm64/boot/dts/amlogic/meson-axg-jethome-jethub-j1xx.dtsi
index afeab89aad8b..8fc7003fd1a0 100644
--- a/arch/arm64/boot/dts/amlogic/meson-axg-jethome-jethub-j1xx.dtsi
+++ b/arch/arm64/boot/dts/amlogic/meson-axg-jethome-jethub-j1xx.dtsi
@@ -18,6 +18,7 @@ aliases {
 		serial0 = &uart_AO;   /* Console */
 		serial1 = &uart_A; /* UART Bluetooth */
 		serial3 = &uart_AO_B; /* ZigBee */
+		//serial6 = &uart_B; /* ZigBee */
 		ethernet0 = &ethmac;
 	};
 
@@ -312,14 +313,6 @@ &sd_emmc_b {
 };
 
 
-/* UART Bluetooth */
-// &uart_B {
-// 	status = "okay";
-// 	pinctrl-0 = <&uart_b_z_pins>, <&uart_b_z_cts_rts_pins>;
-// 	pinctrl-names = "default";
-// 	uart-has-rtscts;
-// };
-
 /* UART Console */
 &uart_AO {
 	status = "okay";
@@ -330,7 +323,7 @@ &uart_AO {
 /* Zigbee */
 &uart_AO_B {
 	status = "okay";
-	pinctrl-0 = <&uart_ao_b_pins>;
+	pinctrl-0 = <&uart_ao_b_z_pins>;
 	pinctrl-names = "default";
 };
 
@@ -342,6 +335,13 @@ &uart_A {
 	uart-has-rtscts;
 };
 
+/* UART Thread */
+//&uart_B {
+//	status = "okay";
+//	pinctrl-0 = <&uart_ao_b_pins>;
+//	pinctrl-names = "default";
+//};
+
 &usb {
 	status = "okay";
 	phy-supply = <&usb_pwr>;
-- 
