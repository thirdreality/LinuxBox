+ {
+	 struct meson_host *host = mmc_priv(mmc);
+ 
+	 host->cmd = NULL;
+	 if (host->needs_pre_post_req)
+		 meson_mmc_post_req(mmc, mrq, 0);
+	 mmc_request_done(host->mmc, mrq);
