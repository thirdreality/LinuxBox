+	DHD_PREALLOC_WIPHY_ESCAN1 = 6,
+	DHD_PREALLOC_DHD_INFO = 7,
+#if defined(BCMSDIO) || defined(BCMDBUS)
+	DHD_PREALLOC_DHD_WLFC_INFO = 8,
