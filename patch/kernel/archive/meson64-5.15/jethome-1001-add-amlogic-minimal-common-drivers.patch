+void pci_reinit(void)
+{
+	struct pci_bus *bus = NULL;
+	int cnt = 20;
+
+	//WIFI_INFO("pci wifi reinit!\n");
+
+	pci_lock_rescan_remove();
+	while ((bus = pci_find_next_bus(bus)) != NULL) {
+		pci_rescan_bus(bus);
+		//WIFI_INFO("rescanning pci device\n");
+		cnt--;
+		if (cnt <= 0)
+			break;
+	}
+	pci_unlock_rescan_remove();
+}
