+	/* config pwm */
+	pwm_init_state(pwm, &pstate);
+	pwm_config(pwm, duty_value, pstate.period);
+	pwm_enable(pwm);
+
+	//WIFI_DEBUG("pwm period val=%lld, pwm duty val=%lld\n",
